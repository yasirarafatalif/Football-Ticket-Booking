DROP TABLE IF EXISTS Bookings;
DROP TABLE IF EXISTS Matches;
DROP TABLE IF EXISTS Users;

-- create users table 
CREATE TABLE Users (
    user_id SERIAL PRIMARY KEY,
    full_name VARCHAR(50),
    email VARCHAR(50) UNIQUE,
    role VARCHAR(20) CHECK (role IN ('Ticket Manager','Football Fan')),
    phone_number VARCHAR(15)
);
-- create matches table
CREATE TABLE Matches (
    match_id SERIAL PRIMARY KEY,
    fixture VARCHAR(100),
    tournament_category VARCHAR(50),
    base_ticket_price DECIMAL(10,2) CHECK (base_ticket_price >= 0),
    match_status VARCHAR(20) CHECK (
        match_status IN ('Scheduled', 'Ongoing', 'Completed', 'Cancelled')
    )
);
-- create bookings table
CREATE TABLE Bookings (
    booking_id serial primary key,
    user_id INT NOT NULL REFERENCES users(user_id),
    match_id INT not null references matches(match_id),
    seat_number varchar not null,
    payment_status VARCHAR(20) check (
        payment_status in ('Pending', 'Confirmed', 'Cancelled', 'Refunded')
    ),
    total_cost DECIMAL(10,2) CHECK (total_cost >= 0)
);

-- find all available matches in the Champions League tournament category
select match_id , fixture, base_ticket_price from matches 
where tournament_category = 'Champions League' and  match_status = 'Available';

-- find all users with names starting with 'Tanvir' or containing 'Haque'
select user_id,full_name , email  from users 
where full_name ilike 'Tanvir%' or full_name ilike '%Haque%';

-- find all bookings with null payment status and replace it with 'Action Required'
select booking_id, user_id,match_id,
  coalesce(payment_status, 'Action Required') as payment_status  from bookings 
where payment_status is null;